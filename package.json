{
  "name": "orb-cascade-neon",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": { "node": ">=22" },
  "pnpm": { "onlyBuiltDependencies": ["esbuild"] },
  "scripts": {
    "dev": "pnpm --filter @orb-cascade-neon/web dev",
    "build": "pnpm --filter @orb-cascade-neon/web build",
    "preview": "pnpm --filter @orb-cascade-neon/web preview",
    "typecheck": "pnpm --filter @orb-cascade-neon/web exec tsc -b",
    "test": "pnpm --filter @orb-cascade-neon/web test"
  }
}
